# === PolarisAI — PRODUCTION .env namunasi ===
# Nusxa oling: cp .env.prod.example .env
# Bu faylni HECH QACHON git'ga commit qilmang.

DJANGO_SECRET_KEY=REPLACE_ME_generate_below
DEBUG=False
# VPS IP manzilingiz (masalan 203.0.113.10). Domen olgach, shu yerga qo'shing:
# ALLOWED_HOSTS=203.0.113.10,example.uz,www.example.uz
ALLOWED_HOSTS=REPLACE_ME_vps_ip

# --- Postgres ---
# Ikkala qatordagi parol BIR XIL bo'lishi shart.
POSTGRES_PASSWORD=REPLACE_ME_strong_password
DATABASE_URL=postgres://travelai:REPLACE_ME_strong_password@db:5432/travelai

REDIS_URL=redis://redis:6379/0

# --- Xavfsizlik: hozircha domen/SSL yo'q, shuning uchun False ---
# Domen + Let's Encrypt sertifikat qo'shgandan keyin bularning barchasini
# True qiling (aks holda login/cookie ishlaydi, lekin brauzer ularni HTTPS
# talab qiladigan qilib belgilamaydi).
AUTH_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.6-flash

# Admin AI yordamchisi (/admin/agent/) uchun ALOHIDA kalit — foydalanuvchi
# chatidan mustaqil hisoblanadi/limitlanadi. Bo'sh qoldirsangiz o'sha sahifa
# oddiy "sozlanmagan" xabarini ko'rsatadi, hech narsa buzilmaydi.
GEMINI_ADMIN_API_KEY=

# --- Email ---
# MUHIM: ro'yxatdan o'tish va parolni tiklash kodlari email orqali yuboriladi.
# Konsol backend (standart) hech qanday real email yubormaydi — kod faqat
# server logida ko'rinadi. Productionda REAL SMTP sozlang, aks holda
# foydalanuvchilar tasdiqlash kodini olmaydi.
#
# Masalan Gmail bilan (2 bosqichli tasdiqlash yoqilgan bo'lishi kerak,
# "App Password" yarating: https://myaccount.google.com/apppasswords):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=sizning-email@gmail.com
# EMAIL_HOST_PASSWORD=REPLACE_ME_app_password
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=PolarisAI <noreply@polarisai.local>

# --- Xatolik kuzatuvi (ixtiyoriy) ---
# Bo'sh qoldirsangiz Sentry ishga tushmaydi. Bepul DSN:
# https://sentry.io -> New Project -> Django
SENTRY_DSN=

# --- Telegram bot (ixtiyoriy) ---
# Bo'sh qoldirsangiz bot butunlay o'chirilgan bo'ladi (bildirishnomalar
# email orqali davom etadi). To'liq sozlash bo'yicha DEPLOY.md'ga qarang.
# 1. @BotFather'da /newbot bilan bot yarating, TOKEN va USERNAME'ni oling.
# 2. TELEGRAM_WEBHOOK_SECRET uchun tasodifiy matn yozing (masalan
#    `python3 -c "import secrets; print(secrets.token_urlsafe(24))"`).
# 3. Deploy qilgandan so'ng webhook'ni bir marta ro'yxatdan o'tkazing:
#    curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<domeningiz>/api/v1/telegram/webhook/<WEBHOOK_SECRET>/"
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
